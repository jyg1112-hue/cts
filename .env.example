OPENAI_API_KEY=
# PostgreSQL (Render Postgres 등): 하역 SQL 테이블 + 관리자 계정(platform_users 테이블) 저장
# DATABASE_URL=postgresql://user:pass@host/dbname
# 미설정 시 관리자 계정은 data/platform_users.json
TAVILY_API_KEY=
OPENAI_SUPPLY_NEWS_MODEL=gpt-4o-mini
TAVILY_SEARCH_DEPTH=basic

# 하역 챗봇 (하이브리드 RAG + SQLite 또는 DATABASE_URL 시 PostgreSQL), 1=활성
UNLOADING_CHAT_ENHANCED=1
# OPENAI_CHAT_MODEL=gpt-5-mini
# HAEYANG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# HAEYANG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
